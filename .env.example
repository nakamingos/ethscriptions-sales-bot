# General Configuration
NODE_ENV=development # production
CARD_GEN_ENABLED=1 # 0 or 1
TWITTER_ENABLED=0 # 0 or 1
SAVE_IMAGES=1 # 0 or 1
TWITTER_TEXT_ONLY_FALLBACK=1 # 0 or 1, retry without media if media upload is blocked
POST_INTERVAL_MS=600000 # Base delay between posts (10 minutes)
POST_INTERVAL_JITTER_MS=120000 # Random +/- jitter added to each post delay (2 minutes)

# Index (n) amount of blocks on start (prioritize this over range)
TEST_WITH_HISTORY= # Block range (ex: 25000)
# Start & end block to index (comma separated)
TEST_WITH_RANGE=22295912,22295920 # 21632952,21632954

# RPC
RPC_URL=

# API (Optional)
ETHSCRIPTIONS_API_BASE_URL=

# Twitter - General (Fallback)
TWITTER_USERNAME=
TWITTER_PASSWORD=
TWITTER_EMAIL=
TWITTER_TWO_FACTOR_SECRET=
TWITTER_COOKIES_JSON=
TWITTER_COOKIES_BASE64=

